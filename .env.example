# Copy to `.env` and fill in secrets. Never commit `.env` or real API keys.
# cp .env.example .env

BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/giftsniper
CHECK_INTERVAL_MINUTES=10
ALERT_COOLDOWN_MINUTES=60
DEFAULT_MARKETPLACE_FEE_PERCENT=5.0
ESTIMATED_EXTRA_COSTS_TON=0.0
MIN_PROFIT_TON=5.0
IMPORTANT_TRAIT_KEYWORDS=monochrome,gold,diamond,legendary,mythic,rare,limited,black,white,silver,platinum
PRICING_TARGET_ROI_CONSERVATIVE=25
PRICING_TARGET_ROI_NORMAL=18
PRICING_TARGET_ROI_AGGRESSIVE=12
PRICING_NO_SALES_SAFE_BUY_DISCOUNT=0.78
PRICING_LOW_CONFIDENCE_DISCOUNT=0.90
PRICING_STALE_DATA_DISCOUNT=0.92
PRICING_RARE_NO_SALES_MAX_TIER=B_TIER
PRICING_STRONG_BUY_MIN_CONFIDENCE=70
PRICING_STRONG_BUY_MIN_LIQUIDITY=60
PRICING_STRONG_BUY_REQUIRE_RECENT_SALES=true
DEFAULT_CURRENCY=TON
DEFAULT_RISK_MODE=normal
ENABLE_MOCK_SOURCE=false
GETGEMS_ENABLED=true
TONAPI_ENABLED=true
TONNEL_ENABLED=true
FRAGMENT_ENABLED=true
GETGEMS_BASE_URL=https://api.getgems.io/public-api
TONAPI_BASE_URL=https://tonapi.io
TONAPI_GLOBAL_RPS_LIMIT=1
TONAPI_GLOBAL_MIN_INTERVAL_MS=1200
# TonAPI Free plan is usually limited to about 1 request/second.
# Keep FULL_MARKET_PAGE_LIMIT <= 1000 and sleeps >= 1200ms unless your TonAPI plan allows more.
# Префикс для ipfs:// ссылок из метаданных NFT (должен заканчиваться на /)
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
# Глобальный индекс NFT (CLI + локальный resolve для /check). По умолчанию выключен.
NFT_GLOBAL_INDEX_ENABLED=false
NFT_GLOBAL_INDEX_PROVIDER=tonapi
NFT_GLOBAL_INDEX_LIMIT_PER_PAGE=1000
NFT_GLOBAL_INDEX_REQUEST_SLEEP_MS=300
NFT_GLOBAL_INDEX_429_BACKOFF_SECONDS=5
NFT_GLOBAL_INDEX_MAX_COLLECTIONS_PER_RUN=0
NFT_GLOBAL_INDEX_SAMPLE_ITEMS=20
NFT_GLOBAL_INDEX_FULL_ITEMS_ENABLED=false
NFT_GLOBAL_INDEX_LIVE_DISCOVERY_FOR_PAID=true
NFT_LIVE_DISCOVERY_PAGE_LIMIT=100
NFT_LIVE_DISCOVERY_MAX_PAGES_FREE=2
NFT_LIVE_DISCOVERY_MAX_PAGES_PAID=30
NFT_LIVE_DISCOVERY_SLEEP_MS=1200
NFT_LIVE_DISCOVERY_429_BACKOFF_SECONDS=10
NFT_LIVE_DISCOVERY_STOP_ON_429=true
# Опционально Toncenter v3 (доп. resolver/discovery, pricing остаётся через TonAPI)
TONCENTER_ENABLED=false
TONCENTER_API_BASE_URL=https://toncenter.com/api/v3
TONCENTER_API_KEY=
TONCENTER_TIMEOUT_SECONDS=15
NFT_GLOBAL_RESOLVER_USE_TONCENTER=true
NFT_GLOBAL_INDEX_LIVE_DISCOVERY_LIMIT=1000
NFT_GLOBAL_INDEX_LIVE_DISCOVERY_MAX_PAGES_FREE=2
NFT_GLOBAL_INDEX_LIVE_DISCOVERY_MAX_PAGES_PAID=30
TONNEL_BASE_URL=
FRAGMENT_BASE_URL=
GETGEMS_API_KEY=
# Реальный ключ только в локальном `.env`, не коммитьте. Получить: https://tonapi.io
TONAPI_API_KEY=
# Full collection scan for /sell_price (TonAPI sale listings, in-memory TTL cache)
FULL_MARKET_SCAN_ENABLED=true
FULL_MARKET_MAX_ITEMS=50000
FULL_MARKET_PAGE_LIMIT=1000
FULL_MARKET_PAGE_LIMIT_MAX=10000
FULL_MARKET_PAGE_LIMIT_FALLBACKS=1000,500,200,100
FULL_MARKET_MIN_PAGE_LIMIT=100
FULL_MARKET_SCAN_MODE=full
FULL_MARKET_FULL_SCAN_ENABLED=true
